// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "linux-musl", "linux-musl-openssl-1.1.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Group {
  id           String       @id @default(cuid())
  name         String       @unique
  theme        String       @unique
  members      String[]     @default([])
  qrCodeLink   String?
  votes        Vote[]
  technologies Technology[] @relation("GroupTechnologies")
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model Technology {
  id        String   @id @default(cuid())
  name      String   @unique
  groups    Group[]  @relation("GroupTechnologies")
  createdAt DateTime @default(now())
}

model Vote {
  id        String   @id @default(cuid())
  ipAddress String
  userAgent String
  fingerprint String? // Extra protection (e.g., persistent cookie ID)
  groupId   String
  group     Group    @relation(fields: [groupId], references: [id])
  timestamp DateTime @default(now())

  @@index([ipAddress, userAgent])
}
